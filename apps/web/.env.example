# Required: Resend API key for contact form emails
RESEND_API_KEY=re_xxxxx

# Admin dashboard secret (used for Bearer token auth)
ADMIN_SECRET=your_admin_secret_here

# Optional: Sanity.io CMS (add when Sanity project is created)
NEXT_PUBLIC_SANITY_PROJECT_ID=xxxxx
NEXT_PUBLIC_SANITY_DATASET=production

# Ireland (IE) pricing adjustments — applied on top of GBP base prices
# Markup multiplier for Ireland market (default: 1.15 = 15% markup)
NEXT_PUBLIC_IE_MARKUP=1.15
# GBP-to-EUR exchange rate (default: 1.17)
NEXT_PUBLIC_IE_EXCHANGE_RATE=1.17
